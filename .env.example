# Firebase Phone Auth — get these from Firebase Console → Project settings → "Your apps" (Web app)
# Leave blank to run the app in demo mode (mock OTP, accepts any 6 digits).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=

# Account Aggregator: URL of YOUR backend proxy (e.g. /api/aa or a deployed function).
# Blank = bank linking uses the demo mock.
VITE_AA_API_URL=
# Do NOT put the Setu client secret in a VITE_* var — it would be exposed in the
# browser bundle. Keep SETU_CLIENT_ID / SETU_CLIENT_SECRET as server-side env on
# the proxy only.

# Logo.dev — real merchant logos (free token at https://logo.dev). Blank = monogram tiles.
VITE_LOGODEV_TOKEN=
