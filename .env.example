# Firebase Phone Auth — get these from Firebase Console → Project settings → "Your apps" (Web app)
# Leave blank to run the app in demo mode (mock OTP, accepts any 6 digits).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=

# Optional: existing Account Aggregator backend (otherwise consent/OTP for bank linking is mocked)
VITE_AA_API_URL=
VITE_AA_API_KEY=

# Logo.dev — real merchant logos (free token at https://logo.dev). Blank = monogram tiles.
VITE_LOGODEV_TOKEN=
