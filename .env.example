# Firebase Phone Auth — get these from Firebase Console → Project settings → "Your apps" (Web app)
# Used as the OTP fallback (see Twilio below) and for Firestore. Leave blank to
# run the app in demo mode (mock OTP, accepts any 6 digits).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=


# Account Aggregator: point the frontend at the bundled proxy. Blank = demo mock.
VITE_AA_API_URL=/api/aa

# --- SERVER-SIDE ONLY (set in Vercel, NOT in the browser bundle) ---
# Read by the /api/aa/* serverless functions. Never prefix these with VITE_.
# Org-service client-credentials login (returns a bearer token used on FIU calls).
SETU_ORG_CLIENT_ID=
SETU_ORG_CLIENT_SECRET=
SETU_ORG_LOGIN_URL=https://orgservice-prod.setu.co/v1/users/login
SETU_PRODUCT_INSTANCE_ID=
SETU_BASE_URL=https://fiu-sandbox.setu.co/v2

# Twilio Verify — primary phone OTP login (/api/otp/*). If unset, the app
# automatically falls back to Firebase Phone Auth, then to the demo mock.
# Get these from the Twilio Console → Account (SID/token) and Verify → Services.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Firebase Admin — mints a custom token after Twilio verifies an OTP, so the
# client can sign in and Firestore persistence (keyed by Firebase uid) keeps
# working. Get from Firebase Console → Project settings → Service accounts →
# Generate new private key. Optional: if unset, Twilio-verified logins just
# skip Firestore sync (localStorage still works).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Logo.dev — real merchant logos (free token at https://logo.dev). Blank = monogram tiles.
VITE_LOGODEV_TOKEN=

# Anthropic API — AI fallback for categorizing bank transactions that the
# keyword rules and learned overrides can't resolve. Read by /api/categorize.
# Get a key at https://console.anthropic.com. Blank = those transactions stay
# categorized as "cash" instead of getting an AI guess.
ANTHROPIC_API_KEY=
